# Porta do servidor HTTP (opcional, padrão: 8080)
PORT=8080

# Conexão com PostgreSQL
DATABASE_URL=postgres://app:app@localhost:5432/notifications

# Endereço do Redis (host:port)
REDIS_ADDR=localhost:6379

# Secret para validação HMAC-SHA256 dos webhooks recebidos
WEBHOOK_SECRET=troque-por-um-valor-aleatorio-seguro

# Chave interna para derivar cidadao_ref a partir do CPF (HMAC-SHA256)
# Deve ser distinta de WEBHOOK_SECRET
CPF_KEY=troque-por-outro-valor-aleatorio-seguro

# URL do JWKS do IdP para validação de JWT RS256
# Em desenvolvimento local aponta para o mock-idp do docker compose
JWT_JWKS_URL=http://localhost:8080/default/.well-known/jwks.json
